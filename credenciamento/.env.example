# ============================================================
# Credenciamento — variáveis de build (Vite)
# Copie para `.env` e preencha. NÃO versione o `.env` real.
# Lembre: tudo que começa com VITE_ é embutido no bundle e fica
# visível no navegador. Use só a ANON KEY (nunca a service_role).
# ============================================================

# URL do projeto Supabase (sem barra no final)
VITE_SUPABASE_URL=https://rsszyvomwndrmjzoaezt.supabase.co

# Chave pública (anon / publishable). Pode aparecer no front.
VITE_SUPABASE_ANON_KEY=sb_publishable_tTuPIVnYKyIIWfRbTqT3UA_Yqu6koSy

# Webhook do n8n disparado ao confirmar presença (boas-vindas).
# Deixe vazio para desligar o WhatsApp (o cadastro no Supabase continua).
# Ex.: https://SEU-N8N/webhook/credenciamento-boas-vindas
VITE_N8N_WEBHOOK_BOAS_VINDAS=

# (Opcional) Segredo enviado no header Authorization: Bearer ...
# Configure o mesmo valor no nó Webhook do n8n para validar a origem.
VITE_WEBHOOK_SECRET=

# Nome do evento exibido na tela e enviado ao n8n
VITE_NOME_EVENTO=Encontro Pepê Collaço 2026

# Código que o operador digita para liberar a tela (camada simples)
VITE_ACCESS_CODE=senhaDoOperador
